{
    "name": "@ingress-shards/iitc-plugin-site-observer",
    "version": "0.0.0-semantically-released",
    "description": "Observes and records site data for Ingress Events.",
    "author": "Lewis Keen",
    "license": "MIT",
    "homepage": "https://ingress-shards.github.io/iitc-plugin-site-observer/",
    "repository": {
        "type": "git",
        "url": "https://github.com/ingress-shards/iitc-plugin-site-observer"
    },
    "bugs": {
        "url": "https://github.com/ingress-shards/iitc-plugin-site-observer/issues"
    },
    "type": "module",
    "private": true,
    "scripts": {
        "build": "yarn build:dev",
        "build:dev": "webpack --config webpack.dev.js",
        "build:prod": "webpack --config webpack.prod.js",
        "start": "yarn ipk fileserver",
        "autobuild": "webpack --watch --config webpack.dev.js",
        "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
        "lint": "eslint src",
        "validate": "yarn clean && yarn lint && yarn build:prod",
        "validate:docker": "node scripts/validate.js"
    },
    "dependencies": {
        "@ingress-shards/ingress-events-core": "0.4.0",
        "idb": "^8.0.3",
        "iitcpluginkit": "^1.9.6",
        "temporal-polyfill": "0.3.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@semantic-release/exec": "^7.1.0",
        "@types/node": "^25.0.9",
        "concurrently": "^9.2.1",
        "conventional-changelog-conventionalcommits": "^9.1.0",
        "eslint": "^9.39.2",
        "eslint-plugin-prefer-arrow-functions": "^3.9.1",
        "eslint-plugin-unicorn": "^62.0.0",
        "semantic-release": "^25.0.2",
        "source-map-loader": "^5.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.52.0",
        "webpack": "^5.104.1",
        "webpack-bundle-analyzer": "^5.3.0"
    },
    "packageManager": "yarn@4.12.0"
}
