{
    "compilerOptions": {
        "module": "ES2022",
        "target": "ES2022",
        "lib": ["ES2022", "dom"],
        "outDir": "dist/",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "typeRoots": ["./node_modules/@types", "./types", "./node_modules/iitcpluginkit/types"],
        "types": ["jquery", "build_constances", "greasemonkey", "iitc", "jqueryui", "leaflet", "images", "node"],
        "forceConsistentCasingInFileNames": true,
        "noImplicitReturns": true,
        "noImplicitAny": true,
        "noImplicitThis": true,
        "alwaysStrict": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "noUnusedLocals": true
    },
    "types": ["webpack-env"],
    "files": ["src/Main.ts"],
    "include": ["types/*.d.ts", "./src/**/*"]
}
